{
  "name": "vrchat-osc-keyboard",
  "productName": "VRChat OSC Keyboard",
  "version": "2.1.0",
  "description": "A Japanese/English virtual keyboard and chatbox interface designed for SteamVR overlays to send text to VRChat via OSC.",
  "napi": {
    "binaryName": "vr-overlay-native",
    "targets": [
      "x86_64-pc-windows-msvc"
    ]
  },
  "author": {
    "name": "fuku_2019"
  },
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"cross-env IS_ELECTRON=true vite\" \"wait-on tcp:5173 && electron .\"",
    "dist": "vite build && electron-builder && node scripts/rename-build-output.js",
    "test": "vitest",
    "test:run": "vitest run",
    "build:native": "napi build --platform --release --manifest-path ./native/Cargo.toml && node scripts/sync-native.cjs",
    "ime:build-dict": "node scripts/ime/build-mozc-shards.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "gl-matrix": "^3.4.4",
    "node-osc": "^11.2.2",
    "react-colorful": "^5.6.1",
    "ws": "^8.19.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.4.1",
    "electron-builder": "^26.8.0",
    "jsdom": "^28.1.0",
    "lucide-react": "^0.564.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "glob": "^10.4.5",
    "rimraf": "^6.0.1",
    "tar": "^7.5.4"
  },
  "build": {
    "npmRebuild": false,
    "afterPack": "./scripts/removeLocales.cjs",
    "asarUnpack": [
      "img/**/*",
      "native/**/*",
      "steamvr/**/*"
    ],
    "publish": null,
    "appId": "com.vrchat.osc.keyboard",
    "productName": "VRChat OSC Keyboard",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "electron/assets/ime/mozc/**/*",
      "package.json",
      "THIRD_PARTY_MOZC_DICTIONARY_LICENSES.txt",
      "native/index.node",
      "native/openvr_api.dll",
      "img/**/*",
      "steamvr/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "legalTrademarks": "VRChat OSC Keyboard",
      "executableName": "VRChat-OSC-Keyboard",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
